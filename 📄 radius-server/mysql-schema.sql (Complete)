-- ============================================================================
-- Stored Procedures for User Management
-- ============================================================================

DELIMITER //

-- Add User Procedure
CREATE PROCEDURE `add_user`(
  IN p_username VARCHAR(64),
  IN p_password VARCHAR(64),
  IN p_package VARCHAR(64),
  IN p_user_type VARCHAR(20)
)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    ROLLBACK;
    SELECT 'Error adding user' AS message;
  END;

  START TRANSACTION;
  
  -- Add to radcheck
  INSERT INTO radcheck (username, attribute, op, value)
  VALUES (p_username, 'Cleartext-Password', ':=', p_password);
  
  -- Add to radusergroup
  INSERT INTO radusergroup (username, groupname, priority)
  VALUES (p_username, 'default', 1);
  
  INSERT INTO radusergroup (username, groupname, priority)
  VALUES (p_username, p_package, 2);
  
  COMMIT;
  
  SELECT 'User added successfully' AS message;
END //

-- Remove User Procedure
CREATE PROCEDURE `remove_user`(
  IN p_username VARCHAR(64)
)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    ROLLBACK;
    SELECT 'Error removing user' AS message;
  END;

  START TRANSACTION;
  
  DELETE FROM radcheck WHERE username = p_username;
  DELETE FROM radusergroup WHERE username = p_username;
  DELETE FROM radreply WHERE username = p_username;
  DELETE FROM radacct WHERE username = p_username;
  
  COMMIT;
  
  SELECT 'User removed successfully' AS message;
END //

-- Get User Details Procedure
CREATE PROCEDURE `get_user_details`(
  IN p_username VARCHAR(64)
)
BEGIN
  SELECT 
    rc.username,
    rc.value AS password,
    rg.groupname AS package,
    rg.priority,
    ra.acctinputoctets AS total_download,
    ra.acctoutputoctets AS total_upload,
    ra.acctsessiontime AS total_time,
    ra.acctstarttime AS last_session_start
  FROM radcheck rc
  LEFT JOIN radusergroup rg ON rc.username = rg.username
  LEFT JOIN radacct ra ON rc.username = ra.username
  WHERE rc.username = p_username
  ORDER BY ra.acctstarttime DESC
  LIMIT 1;
END //

-- Get Active Users Procedure
CREATE PROCEDURE `get_active_users`()
BEGIN
  SELECT 
    username,
    framedipaddress AS ip_address,
    callingstationid AS mac_address,
    acctstarttime AS start_time,
    acctsessiontime AS session_time,
    acctinputoctets AS download,
    acctoutputoctets AS upload
  FROM radacct
  WHERE acctstoptime IS NULL
  ORDER BY acctstarttime DESC;
END //

-- Get Usage Statistics Procedure
CREATE PROCEDURE `get_usage_stats`(
  IN p_username VARCHAR(64),
  IN p_start_date DATETIME,
  IN p_end_date DATETIME
)
BEGIN
  SELECT 
    SUM(acctinputoctets) AS total_download,
    SUM(acctoutputoctets) AS total_upload,
    SUM(acctsessiontime) AS total_time,
    COUNT(*) AS sessions
  FROM radacct
  WHERE username = p_username
    AND acctstarttime BETWEEN p_start_date AND p_end_date;
END //

DELIMITER ;

-- ============================================================================
-- Triggers
-- ============================================================================

-- Log User Login Trigger
DELIMITER //

CREATE TRIGGER `log_user_login` 
AFTER INSERT ON `radacct`
FOR EACH ROW
BEGIN
  INSERT INTO user_activity (username, action, ip_address, session_id)
  VALUES (NEW.username, 'login', NEW.framedipaddress, NEW.acctsessionid);
END //

DELIMITER ;

-- ============================================================================
-- Views for Reporting
-- ============================================================================

-- Active Users View
CREATE OR REPLACE VIEW `v_active_users` AS
SELECT 
  username,
  framedipaddress AS ip_address,
  callingstationid AS mac_address,
  acctstarttime AS login_time,
  acctsessiontime AS session_seconds,
  acctinputoctets AS downloaded_bytes,
  acctoutputoctets AS uploaded_bytes,
  acctinputoctets + acctoutputoctets AS total_bytes,
  nasipaddress AS nas_ip
FROM radacct
WHERE acctstoptime IS NULL;

-- User Summary View
CREATE OR REPLACE VIEW `v_user_summary` AS
SELECT 
  rc.username,
  rc.value AS password,
  MAX(rg.groupname) AS package,
  COUNT(ra.radacctid) AS total_sessions,
  SUM(ra.acctsessiontime) AS total_time_seconds,
  SUM(ra.acctinputoctets) AS total_download_bytes,
  SUM(ra.acctoutputoctets) AS total_upload_bytes,
  MAX(ra.acctstarttime) AS last_login,
  CASE 
    WHEN MAX(ra.acctstoptime) IS NULL THEN 'Active'
    ELSE 'Inactive'
  END AS status
FROM radcheck rc
LEFT JOIN radusergroup rg ON rc.username = rg.username
LEFT JOIN radacct ra ON rc.username = ra.username
WHERE rc.attribute = 'Cleartext-Password'
GROUP BY rc.username, rc.value;

-- Billing Summary View
CREATE OR REPLACE VIEW `v_billing_summary` AS
SELECT 
  i.username,
  COUNT(i.id) AS total_invoices,
  SUM(i.amount) AS total_amount,
  SUM(i.paid_amount) AS total_paid,
  SUM(i.amount - i.paid_amount) AS total_due,
  COUNT(CASE WHEN i.status = 'pending' THEN 1 END) AS pending_invoices,
  COUNT(CASE WHEN i.status = 'overdue' THEN 1 END) AS overdue_invoices
FROM invoices i
GROUP BY i.username;

